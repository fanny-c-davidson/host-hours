# ─────────────────────────────────────────────────────────────────────────────
# Host Hours — environment variables
#
# Copy this file to `.env.local` for local development and fill in real values.
# In production, set these in your host's environment (Vercel/Netlify/etc.).
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser; the rest are
# server-only — never expose SUPABASE_SERVICE_ROLE_KEY or STRIPE_* secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# Base URL of the app; used to build invitation links. Use your real domain in prod.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and anon (publishable) key — from Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Service-role key — bypasses RLS. SERVER ONLY. Used by the Stripe webhook and
# self-authorizing team server actions. Keep this secret.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Cloudflare R2 (receipt photo storage) ───────────────────────────────────
# S3-compatible object storage for receipt photos. SERVER ONLY — the browser
# never gets these; uploads/reads go through /api/receipt. Create an R2 bucket
# and an API token (Object Read & Write) in the Cloudflare dashboard.
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_BUCKET="host-hours-receipts"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"

# ── Mapbox ───────────────────────────────────────────────────────────────────
# Token for property address autocomplete (Mapbox Geocoding).
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your-mapbox-token"

# ── Resend (transactional email) ─────────────────────────────────────────────
# API key — from Resend → API Keys.
RESEND_API_KEY="re_your-api-key"
# Sender address. MUST be on a domain you've verified in Resend, or sends fail
# with a 403 ("can only send to your own email"). The default resend.dev domain
# is testing-only. Format: "Display Name <address@your-verified-domain.com>".
RESEND_FROM_EMAIL="Host Hours <noreply@your-verified-domain.com>"

# ── Stripe (billing) ─────────────────────────────────────────────────────────
# Secret key and webhook signing secret — from the Stripe dashboard.
STRIPE_SECRET_KEY="sk_test_your-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
# Price IDs for each plan/interval — from Stripe → Products.
STRIPE_PRICE_STARTER_MONTHLY="price_..."
STRIPE_PRICE_STARTER_YEARLY="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_YEARLY="price_..."
STRIPE_PRICE_BUSINESS_MONTHLY="price_..."
STRIPE_PRICE_BUSINESS_YEARLY="price_..."
