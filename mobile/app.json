{
  "expo": {
    "name": "Host Hours",
    "slug": "host-hours",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "hosthours",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#FBF8F1",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hosthours.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hosthours.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
