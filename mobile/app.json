{
  "expo": {
    "name": "Host Hours",
    "slug": "host-hours",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "hosthours",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#FBF8F1",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hosthours.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["location", "fetch", "remote-notification"]
      }
    },
    "android": {
      "package": "com.hosthours.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      [
        "expo-local-authentication",
        { "faceIDPermission": "Use Face ID to unlock Host Hours." }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Host Hours needs photo access to attach receipts.",
          "cameraPermission": "Host Hours needs the camera to capture receipts."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Host Hours uses your location to auto start and stop the timer at your properties.",
          "locationWhenInUsePermission": "Host Hours uses your location to auto start and stop the timer at your properties.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-notifications",
      "expo-task-manager"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
